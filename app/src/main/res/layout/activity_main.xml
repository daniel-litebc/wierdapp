<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/header_gradient"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alert System"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connecting..."
            android:textSize="16sp"
            android:textColor="#E0E0E0"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ready for alerts"
            android:textSize="14sp"
            android:textColor="#B0BEC5" />

    </LinearLayout>

    <!-- Controls Section -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Checkboxes Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginBottom="16dp" />

                <CheckBox
                    android:id="@+id/cbSleepWindow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Asleep but with open window"
                    android:textSize="14sp"
                    android:textColor="#424242"
                    android:layout_marginBottom="12dp"
                    android:padding="8dp" />

                <CheckBox
                    android:id="@+id/cbWindow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Window closed"
                    android:textSize="14sp"
                    android:textColor="#424242"
                    android:padding="8dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Alert Button Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <Button
            android:id="@+id/btnAlert"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:text="ALERT"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_alert"
            android:elevation="8dp" />

    </LinearLayout>

</LinearLayout>
